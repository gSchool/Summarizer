# LLM backend: "gemini" (default) or "ollama".
LLM_PROVIDER=gemini

# --- Gemini (LLM_PROVIDER=gemini) ---
# Set one of these keys. GEMINI_API_KEY is preferred here.
GEMINI_API_KEY=
# Optional alternative recognized by some Google SDKs
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Ollama (LLM_PROVIDER=ollama) ---
# Local Ollama server; no API key needed. Defaults shown.
OLLAMA_MODEL=qwen3.5
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

